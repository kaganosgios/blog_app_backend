{
  "info": {
    "name": "Multi User Blog API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for testing the multi user blog API"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" },
    { "key": "postId", "value": "" },
    { "key": "commentId", "value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/health"
      }
    },
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/register"
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"123456\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      }
    },
    {
      "name": "Get Profile",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/users/me"
      }
    },
    {
      "name": "Update Profile",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "name", "value": "Updated User", "type": "text" },
            { "key": "bio", "value": "Backend developer", "type": "text" },
            { "key": "avatar", "type": "file", "src": "" }
          ]
        },
        "url": "{{baseUrl}}/api/users/me"
      }
    },
    {
      "name": "Create Post",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "title", "value": "My first blog post", "type": "text" },
            { "key": "content", "value": "This is the content of the blog post.", "type": "text" },
            { "key": "tags", "value": "nodejs,express,mongodb", "type": "text" },
            { "key": "image", "type": "file", "src": "" }
          ]
        },
        "url": "{{baseUrl}}/api/posts"
      }
    },
    {
      "name": "Get Posts",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/posts?sort=popular&tag=nodejs"
      }
    },
    {
      "name": "Get Post By Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/posts/{{postId}}"
      }
    },
    {
      "name": "Update Post",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "title", "value": "Updated title", "type": "text" },
            { "key": "content", "value": "Updated content", "type": "text" },
            { "key": "tags", "value": "api,backend", "type": "text" }
          ]
        },
        "url": "{{baseUrl}}/api/posts/{{postId}}"
      }
    },
    {
      "name": "Like Post",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/posts/{{postId}}/like"
      }
    },
    {
      "name": "Add Comment",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"content\": \"Great post!\"\n}"
        },
        "url": "{{baseUrl}}/api/posts/{{postId}}/comments"
      }
    },
    {
      "name": "Reply Comment",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"content\": \"Reply to comment\",\n  \"parentComment\": \"{{commentId}}\"\n}"
        },
        "url": "{{baseUrl}}/api/posts/{{postId}}/comments"
      }
    },
    {
      "name": "Update Comment",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"content\": \"Edited comment\"\n}"
        },
        "url": "{{baseUrl}}/api/comments/{{commentId}}"
      }
    },
    {
      "name": "Delete Comment",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/comments/{{commentId}}"
      }
    },
    {
      "name": "Delete Post",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/api/posts/{{postId}}"
      }
    }
  ]
}
